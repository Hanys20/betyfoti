---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="DOMŮ - Fotografka Alžběta Zajíčková"
  description="Fotografka Alžběta Zajíčková z Olomouce. Zachycuji lásku, emoce a autentické momenty — příběhy, svatby a brand fotografie s duší."
>

  <!-- HERO CAROUSEL -->
  <section class="hero-section">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-nahore-4.jpg" alt="Portfolio" loading="eager" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2024/10/DSC02843-2.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-nahore-5.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2024/10/DSC06296-2.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-nahore-1.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC04621.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2024/10/DSC04335.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2024/10/DSC00994.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-nahore-3.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-nahore-2.jpg" alt="Portfolio" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- HERO TEXT -->
  <section class="hero-text">
    <h1 class="serif-heading">LÁSKA, EMOCE, MOMENTY</h1>
    <h2 class="script-heading hero-sub">skutečný příběh</h2>
  </section>

  <!-- ABOUT BETY -->
  <section class="two-col-section">
    <div class="two-col-inner">
      <div class="about-img">
        <img
          src="/wp-content/uploads/2024/10/Bety-webovky-11.png"
          alt="Fotografka Alžběta Zajíčková"
          loading="lazy"
        />
      </div>
      <div class="two-col-text">
        <p class="eyebrow">AHOOJ, VÍTEJ, JMENUJI SE ALŽBĚTA, ALE…</p>
        <h2>ŘÍKAJÍ MI BETY</h2>
        <p>Setkávání se s lidmi a vzájemné sdílení mě neskutečně naplňuje. Díky fotografii mohu nahlédnout do vašich příběhů a zároveň v nich zanechat i kousek sebe. Miluju možnost zaznamenat vaši jedinečnost a emoce tak, aby fotografie přirozeně odrážela to, kým jste. Tvořím vzpomínky, které vyzařují lásku.</p>
        <a href="/o-mne/" class="btn" style="margin-top:1.6rem">více o mně</a>
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="quote-section">
    <h2>VÁŠ ŽIVOT NEMUSÍ BÝT DOKONALÝ, ABY BYL KRÁSNÝ</h2>
    <h2 class="script">- je krásný, protože je váš.</h2>
  </section>

  <!-- CO FOTÍM -->
  <section class="co-fotim-section">
    <div class="co-fotim-header">
      <h2 class="script-heading co-fotim-title">co fotím?</h2>
      <p>Prostě lásku v různých podobách a všechny (ne)obyčejné střípky z vašeho (ne)všedního života.</p>
    </div>
    <div class="category-grid">
      <a href="/pribehy/" class="category-card">
        <img src="/wp-content/uploads/2024/10/Pribehy-opraveny.png" alt="Matka s dcerami při procházce lesem" loading="lazy" />
        <span class="category-card-label">Příběhy</span>
      </a>
      <a href="/svatby/" class="category-card">
        <img src="/wp-content/uploads/2024/10/Svatby-opraveny.png" alt="Nevěsta a ženich se líbají pod svatební bránou" loading="lazy" />
        <span class="category-card-label">Svatby</span>
      </a>
      <a href="/brand/" class="category-card">
        <img src="/wp-content/uploads/2024/10/Brand-opraveny.png" alt="Detailní záběr na šálek cappuccina" loading="lazy" />
        <span class="category-card-label">Brand</span>
      </a>
    </div>
  </section>

  <!-- BOTTOM CAROUSEL -->
  <section style="padding: 40px 0;">
    <div class="swiper bottom-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-dole-1-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC01406-2-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC01963-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC05914-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-dole-2-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC00067-2-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC07038-3-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC07608-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC02664-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2026/02/uvod-dole-3-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC07929-Edit-2-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC01169-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC03695-2-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
        <div class="swiper-slide"><img src="/wp-content/uploads/2025/02/DSC08000-683x1024.jpg" alt="Portfolio" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials-section">
    <div class="testimonials-section-inner">
      <div class="testimonials-header">
        <h2 class="serif-heading">milá slova</h2>
        <h2 class="script">děkuji za Vás!</h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <img class="testimonial-photo" src="/wp-content/uploads/2025/02/DSC06114.jpg" alt="Dominika a Vojta" loading="lazy" />
          <div class="testimonial-quote">&ldquo;</div>
          <p class="testimonial-text">Hrozně nerada se fotím, ale s Bety jsem se uvolnila a výsledek za to rozhodně stojí. Skvělá spolupráce, rozhodně doporučujeme!</p>
          <p class="testimonial-author">Dominika a Vojta</p>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-quote">&ldquo;</div>
          <p class="testimonial-text">Focení s Bety bylo absolutně přirozené a nenásilné. Člověk se cítí velmi dobře i když není příliš zvyklý se fotit a pózovat. Bety krásně pomáhá navést co dělat, jak si stoupnout, hýbat se a focení krásně plyne. Za mě má úžasné nadání pro přirozené zachycení přítomného okamžiku, a i pro následnou úpravu výsledných fotek. Velmi se mi líbí i to, že fotky působí jemně a žensky. Za mě to byla boží spolupráce, takže vřele doporučuji.</p>
          <p class="testimonial-author">Alice</p>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-quote">&ldquo;</div>
          <p class="testimonial-text">Neodolala jsem… jsou krásné!! moccc děkujeme!!! Těšíme se, až některé vytiskneme na plátno a budou dominantou našeho domu!</p>
          <p class="testimonial-author">Petra</p>
        </div>
        <div class="testimonial-card">
          <img class="testimonial-photo" src="/wp-content/uploads/2024/10/DSC08439.jpg" alt="Míša" loading="lazy" />
          <div class="testimonial-quote">&ldquo;</div>
          <p class="testimonial-text">Tak jsem zkoukla fotky a jsem nadšená. Mám pocit, že ty fotky mě opravdu vystihují. Líbí se mi tvoje práce a tvůj přístup k focení. Jde vidět, že to děláš srdcem. Ještě jednou děkujeme a když se mě někdo zeptá jestli znám skvělou fotografku, tak vím, že doporučím tebe!</p>
          <p class="testimonial-author">Míša</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bety-cta-section">
    <div class="bety-cta-deco">vzpomínky</div>
    <div class="bety-cta-inner">
      <p class="bety-cta-eyebrow">Pojďme tvořit</p>
      <h2 class="bety-cta-heading">Zachytím váš příběh</h2>
      <p class="bety-cta-text">Ozvi se mi — ráda si popovídáme o vaší představě a vymyslíme focení přesně pro vás.</p>
      <a href="/kontakt/" class="btn">Kontaktujte mě</a>
    </div>
  </section>

</Layout>

<style>
  .hero-section { width: 100%; }
  .hero-swiper { height: clamp(280px, 55vw, 600px); }
  .hero-swiper .swiper-slide img { width: 100%; height: 100%; object-fit: cover; }

  .hero-text {
    text-align: center;
    padding: 60px 24px 48px;
  }
  .hero-text h1 {
    font-size: clamp(2rem, 5vw, 4rem);
    color: #3a3330;
    text-transform: uppercase;
    letter-spacing: .06em;
    font-weight: 400;
  }
  .hero-sub {
    font-size: clamp(2.2rem, 5vw, 4rem);
    color: #9a8f8b;
    display: inline-block;
    transform: rotate(-2deg);
    margin-top: .4rem;
  }

  .co-fotim-section { padding-bottom: 0; }
  .co-fotim-header { text-align: center; padding: 60px 24px 32px; }
  .co-fotim-title { font-size: clamp(2.4rem, 6vw, 4.4rem); color: #3a3330; margin-bottom: .6rem; }
  .co-fotim-header p { font-size: .95rem; color: #7a6f6c; max-width: 480px; margin: 0 auto; line-height: 1.75; }

  .bottom-swiper { height: clamp(220px, 40vw, 420px); }
  .bottom-swiper .swiper-slide img { width: 100%; height: 100%; object-fit: cover; }
</style>

<script>
  import Swiper from 'swiper';
  import { Autoplay } from 'swiper/modules';
  import 'swiper/css';

  new Swiper('.hero-swiper', {
    modules: [Autoplay],
    loop: true,
    spaceBetween: 3,
    autoplay: { delay: 3000, disableOnInteraction: false },
    breakpoints: {
      0:    { slidesPerView: 1 },
      768:  { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });

  new Swiper('.bottom-swiper', {
    modules: [Autoplay],
    loop: true,
    spaceBetween: 3,
    autoplay: { delay: 3200, disableOnInteraction: false },
    breakpoints: {
      0:    { slidesPerView: 2 },
      768:  { slidesPerView: 3 },
      1024: { slidesPerView: 4 },
    },
  });
</script>
