---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="KONTAKT - Fotografka Alžběta Zajíčková"
  description="Napiš mi nebo zavolej — ráda si popovídáme o vašem focení. Působím v okolí Olomouce a Opavy, cestovat nevadí."
  canonical="kontakt/"
>

  <!-- HERO -->
  <section class="page-hero">
    <h1>kontakt</h1>
    <h2 class="script">pojďme se poznat</h2>
  </section>

  <!-- FORMS -->
  <section class="kontakt-section">
    <div class="kontakt-inner">

      <!-- PŘÍBĚHY & BRAND -->
      <div class="kontakt-form-block">
        <h2 class="kontakt-form-label">příběhy a brand</h2>
        <ContactForm action="https://formspree.io/f/xjgdzglb" />
      </div>

      <!-- DIVIDER -->
      <div class="kontakt-divider"></div>

      <!-- SVATEBNÍ FOCENÍ -->
      <div class="kontakt-form-block">
        <h2 class="kontakt-form-label">svatební focení</h2>
        <ContactForm action="https://formspree.io/f/maqzkqvn" type="wedding" />
      </div>

      <!-- SIDEBAR -->
      <div class="kontakt-sidebar">
        <div class="kontakt-signature-block">
          <span class="contact-signature">Bety Zajíčková</span>
        </div>
        <p class="kontakt-sidebar-text">Kontaktovat mě můžeš také na telefonní číslo a e-mail</p>
        <a href="tel:+420733670860" class="kontakt-contact-item">733&nbsp;670&nbsp;860</a>
        <a href="mailto:bety.zajickova.foto@seznam.cz" class="kontakt-contact-item">bety.zajickova.foto@seznam.cz</a>
      </div>

    </div>
  </section>

</Layout>

<style>
  .kontakt-section { padding: 60px 40px 100px; }

  .kontakt-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    gap: 0 40px;
    align-items: start;
  }

  .kontakt-form-label {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 400;
    color: var(--color-ink);
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: 2rem;
  }

  .kontakt-divider {
    width: 1px;
    background: var(--color-border);
    align-self: stretch;
    margin: 0 8px;
  }

  .kontakt-sidebar {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 12px;
    min-width: 200px;
  }

  .kontakt-sidebar-text {
    font-size: .82rem;
    color: var(--color-light);
    line-height: 1.6;
  }

  .kontakt-contact-item {
    font-size: .88rem;
    color: var(--color-dark);
    font-weight: 500;
    text-decoration: none;
    transition: color .2s;
    display: block;
  }
  .kontakt-contact-item:hover { color: var(--color-mid); }

  .kontakt-signature-block { margin-bottom: 8px; }

  @media (max-width: 1024px) {
    .kontakt-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .kontakt-divider { width: 100%; height: 1px; margin: 0; }
  }

  @media (max-width: 600px) {
    .kontakt-section { padding: 40px 20px 80px; }
  }
</style>
