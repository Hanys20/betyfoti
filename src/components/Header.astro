---
const navLinks = [
  { label: 'Domů', href: '/' },
  {
    label: 'Co fotím',
    href: '/co-fotim/',
    children: [
      { label: 'Příběhy', href: '/pribehy/' },
      { label: 'Svatby', href: '/svatby/' },
      { label: 'Brand', href: '/brand/' },
    ],
  },
  { label: 'O mně', href: '/o-mne/' },
  { label: 'FAQ', href: '/faq/' },
  { label: 'Kontakt', href: '/kontakt/' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img
        src="/wp-content/uploads/2024/10/Bety-logo_Kreslici-platno-1-kopie-11.png"
        alt="Bety Foti — Alžběta Zajíčková"
        width="200"
        height="96"
      />
    </a>

    <nav class="header-nav" aria-label="Hlavní navigace">
      <ul>
        {navLinks.map(link => (
          link.children ? (
            <li class="nav-dropdown">
              <a href={link.href}>{link.label}</a>
              <ul class="dropdown-menu">
                {link.children.map(child => (
                  <li><a href={child.href}>{child.label}</a></li>
                ))}
              </ul>
            </li>
          ) : (
            <li><a href={link.href}>{link.label}</a></li>
          )
        ))}
      </ul>
    </nav>

    <button class="bety-ham" aria-label="Otevřít menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>
